# Supabase — get these from your Supabase project settings
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# PostHog — get this from posthog.com project settings
EXPO_PUBLIC_POSTHOG_KEY=phc_your-posthog-key

# Branch.io — get this from branch.io dashboard
EXPO_PUBLIC_BRANCH_KEY=key_live_your-branch-key
