{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watchAll"
  },
  "jest": {
    "projects": [
      {
        "displayName": "utils",
        "testEnvironment": "node",
        "testMatch": [
          "<rootDir>/__tests__/isOpenNow.test.ts",
          "<rootDir>/__tests__/formatWhatsApp.test.ts"
        ],
        "transform": {
          "^.+\\.tsx?$": [
            "ts-jest",
            {
              "tsconfig": {
                "strict": false
              }
            }
          ]
        }
      },
      {
        "displayName": "app",
        "preset": "jest-expo",
        "testMatch": [
          "<rootDir>/__tests__/**/*.test.tsx"
        ],
        "transformIgnorePatterns": [
          "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*)"
        ]
      }
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "^2.99.1",
    "@tanstack/react-query": "^5.90.21",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~55.0.6",
    "expo-apple-authentication": "^55.0.8",
    "expo-auth-session": "^55.0.8",
    "expo-blur": "~55.0.9",
    "expo-camera": "~55.0.18",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.16",
    "expo-file-system": "~55.0.11",
    "expo-font": "~55.0.8",
    "expo-image": "^55.0.6",
    "expo-image-manipulator": "^55.0.10",
    "expo-image-picker": "^55.0.13",
    "expo-linear-gradient": "~55.0.8",
    "expo-linking": "^55.0.7",
    "expo-localization": "~55.0.8",
    "expo-location": "~55.1.2",
    "expo-notifications": "~55.0.25",
    "expo-router": "^55.0.5",
    "expo-status-bar": "~55.0.4",
    "expo-video": "~55.0.11",
    "expo-web-browser": "^55.0.9",
    "i18next": "^25.8.18",
    "posthog-react-native": "^3.16.1",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.8",
    "react-native": "0.83.2",
    "react-native-maps": "1.26.20",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.10",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.9",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "private": true
}
